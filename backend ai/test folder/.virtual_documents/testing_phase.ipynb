# LLM models
llm_small = ChatMistralAI(model="mistral-small-latest", api_key=MISTRAL_API_KEY, temperature=0)
llm_large = ChatMistralAI(model="mistral-large-latest", api_key=MISTRAL_API_KEY, temperature=0)

